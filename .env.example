# Copy to `.env` and fill in. Each platform is optional; configure the one(s) you use.

# Storage (SQLite file, created automatically).
DATABASE_URL=sqlite://krappe.db

# --- Telegram ---
# Get a token from @BotFather. Add the bot to your group and, for /naamat to set
# custom admin titles, make it an admin with "Add new admins" permission.
TELOXIDE_TOKEN=

# --- IRC ---
# The bot must be opped in the channel to grant +v (!krappe) and +o (!naamat).
IRC_SERVER=irc.libera.chat
IRC_PORT=6697
IRC_USE_TLS=true
IRC_NICK=krappebot
# IMPORTANT: quote channel names — an unquoted leading '#' is parsed as a comment
# (so the value becomes empty and the bot joins nothing). Comma-separate multiple.
IRC_CHANNELS="#yourchannel"
# Optional: identify with NickServ on connect.
IRC_NICKSERV_PASSWORD=

# Optional: logging verbosity, e.g. info, debug, krappebot=debug
RUST_LOG=info,krappebot=info
